---
import json from "@data/financialProjections.json";
---

<!-- SOTO HJÆLP, FULL BLEED VIRKER IKKE -->
<section class="full-bleed">
  <div class="top">
    <div class="header-content">
      <h2>FINANCIAL TOOLS</h2>
      <h3>Financial Projects</h3>
      <p>
        Financial projections are essential for planning and monitoring a
        company’s performance.
      </p>
    </div>

    <div class="arrow-content">
      <svg
        class="arrowBtn"
        width="25"
        height="21"
        viewBox="0 0 25 21"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M22.6947 10.3839L1.82227 10.3839M1.82227 10.3839L10.3609 18.9222M1.82227 10.3839L10.3609 1.84473"
          stroke="currentcolor"
          stroke-width="3.19444"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>

      <svg
        class="arrowBtn"
        width="25"
        height="22"
        viewBox="0 0 25 22"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        stroke-width="3.23715"
      >
        <path
          d="M1.68262 10.8491H22.8341M22.8341 10.8491L14.1812 2.19629M22.8341 10.8491L14.1812 19.5021"
          stroke="currentcolor"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </div>
  </div>

  <div class="cards-container">
    {
      json.values.map(({ icon, title, description }) => (
        <div class="card">
          <img class="icon-img" src={`/src/icons/${icon}.svg`} alt="" />
          <div class="card-text">
            <h1>{title}</h1>
            <p>{description}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  section {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding: 40px;
    background-color: var(--color-neutrals-100);

    .top {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 40px;

      .header-content {
        max-width: 500px;
      }
    }
    path {
      stroke: white;
    }

    .arrow-content {
      display: flex;
      gap: 15px;

      .arrowBtn {
        background-color: #111827;
        border: none;
        border-radius: 50%;
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: opacity 0.2s;
      }

      .arrowBtn:hover {
        background-color: red;

        path {
          stroke: black;
        }
      }

      .arrowBtn img {
        width: 20px;
      }
    }
  }

  .card-container {
    overflow: hidden;
  }

  .card {
    background-color: var(--color-surface-tertiary);
  }
</style>
