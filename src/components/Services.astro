---
import ServiceCard from "@components/ServiceCard.astro";
import servicesData from "@data/services.json";
import DynamicImage from "@helpers/DynamicImage.astro";
---

<div class="services">
  {servicesData.services.map((service) => <ServiceCard service={service} />)}
</div>

<style>
  @layer components {
    .services {
      display: flex;
      flex-direction: row;
      margin-top: -8rem;
      gap: 1rem;
      margin-inline: 2rem;
      position: relative;
      top: 129px;
      margin-bottom: 20px;
    }
  }
</style>
