---
import Logo from "@data/images/Logo.gul.svg";
import "../styles/tokens.css";
import DropdownLogin from "./DropdownLogin.astro";
---

<header>
  <div>
    <Logo />
    <nav>
      <a href="/">Home</a>
      <a href="/fakta">Case study</a>
      <a href="/planer">Team</a>
      <a href="/planside">About</a>
    </nav>
    <button popovertarget="pop" anchor-name="--nav-btn">Login</button>
    <DropdownLogin />
  </div>
</header>

<style>
  header {
    background-color: var(--color-neutrals-900);
    padding-block: 2rem;

    div {
      /* display: flex;
      justify-content: space-between; */
      display: grid;
      grid-template-columns: 1fr 2fr 1fr;
    }
  }

  nav a {
    font-family: "Inter", sans-serif;
    font-optical-sizing: auto;
    font-size: x-large;
    font-style: normal;
  }

  nav {
    display: flex;
    gap: 20px;
    justify-content: center; /* centrer horisontalt */
    align-items: center;
  }

  img {
    width: 20%;
    height: auto;
    padding-left: 3rem;
  }

  a {
    color: rgba(197, 212, 220, 1);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  button {
    margin-right: 200px;
    background: #b1b1b1;
    color: #000000;
    border: none;
    border-radius: 25px;
    padding: 10px;
    cursor: pointer;
  }
</style>
