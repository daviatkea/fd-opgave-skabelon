---
import { Image } from "astro:assets";
import Services from "./Services.astro";
import CEOImage from "@assets/images/ceo.webp";
---

<section class="hero">
  <div>
    <div class="hero-content">
      <h1>Empowering Your Business Growth</h1>
      <p>
        Discover tailored strategies and expert insights to take your business
        to the next level. Let us help you navigate challenges and achieve
        sustainable success.
      </p>
      <a href="#0">Book a Meeting</a>
      <a href="#0">Learn More</a>
    </div>
    <div class="CEO-image">
      <Image src={CEOImage} alt="CEO" />
      <span class="background-grid"></span>
    </div>
    <Services />
  </div>
</section>

<style>
  /* Styles her */
  @layer components {
    .hero {
      display: grid;
      grid-template-columns: subgrid;
      grid-column: full;
      > :not(&) {
        grid-column: content;
    }

    .CEO-image {
    }
    .background-grid {
      position: relative;
      &::after {
        content: "";
        position: absolute;
        inset: 0;

        background:
          conic-gradient(
              from 180deg at 1px 1px,
              red 75%,
              var(--color-blue-700-transparent) 0
            ) -1px -1px /
            60px 60px,
          transparent;
      }
    }
  }
</style>
