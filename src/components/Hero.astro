---
import { Image } from "astro:assets";
import Services from "./Services.astro";
import CEOImage from "@assets/images/ceo.webp";
---

<section class="hero full-bleed">
  <div class="hero-top">
    <div class="hero-content">
      <h1 class="--cabin-50-bold-white">Empowering Your Business Growth</h1>
      <p class="--lato-18-reg-400muted">
        Discover tailored strategies and expert insights to take your business
        to the next level. Let us help you navigate challenges and achieve
        sustainable success.
      </p>
      <a href="#0">Book a Meeting</a>
      <a href="#0">Learn More</a>
    </div>
    <Image src={CEOImage} alt="CEO" class="ceo" />
  </div>

  <Services />

  <style>
    /* Styles her */
    @layer components {
      .ceo {
        width: 100%;
        height: 135%;
        object-fit: cover;
      }
      .hero {
        background-color: #030712;
        padding: 2rem;
      }
      .hero-content {
        display: grid;
        grid-template-rows: 1fr 1fr;
        padding: 2rem;

        /***HERO BACCKGROUND ***/

        padding: 8lh 1lh;
        --grid-color: oklch(from #ffcc4a l c h / 0.18);
        --grid-size: 60px;

        background:
          radial-gradient(
            ellipse farthest-side at 60% 60%,
            #0000 10%,
            #030712 75%
          ),
          conic-gradient(
              from 180deg at 1px 1px,
              var(--grid-color) 75%,
              #0000 0
            ) -1px -1px /
            var(--grid-size) var(--grid-size),
          #030712;
        color: #fff;
      }

      .hero-top {
        display: grid;
        grid-template-columns: 2fr 3fr;
        grid-template-rows: auto;
      }
      .service {
        display: flex;
        flex-direction: row;
        margin-top: 2rem;
      }
    }
  </style>
</section>
