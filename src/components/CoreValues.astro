---
import Logo from "@data/images/Logo.gul.svg";
import "../styles/tokens.css";
import coreValues from "@data/coreValues.json";

const { title, subtitle, eyebrow } = coreValues;
---

<section class="full-bleed">
  <div class="flex-container">
    <div>
      <h2 class="--lato-16-reg-white">{eyebrow}</h2>
      <h1 class="--cabin-45-bold-white">{title}</h1>
      <p class="--lato-18-reg-white">{subtitle}</p>
    </div>
    <a class="--lato-18-minibold-black" href={coreValues.button.link}
      >{coreValues.button.text}
    </a>
  </div>
  <div class="cards-container">
    {
      coreValues.values.map(
        async ({ icon: iconName, title, description, link }) => {
          const icon = `/src/icons/${iconName}.svg`;

          return (
            <div class="card">
              <img class="icon-img" src={icon} alt="" />
              <div class="card-text">
                <h2 class="--cabin-20-semibold-black">{title}</h2>
                <h3 class="--lato-18-reg-muted">{description}</h3>
                <a class="--lato-18-minibold-black" href="">
                  {link.text}
                </a>
              </div>
            </div>
          );
        },
      )
    }
  </div>
</section>

<style>
  section {
    padding: 8lh 1lh;
    --grid-color: oklch(from #ffcc4a l c h / 0.18);
    --grid-size: 60px;

    background:
      radial-gradient(ellipse farthest-side at 60% 60%, #0000 10%, #030712 75%),
      conic-gradient(
          from 180deg at 1px 1px,
          var(--grid-color) 75%,
          #0000 0
        ) -1px -1px /
        var(--grid-size) var(--grid-size),
      #030712;
    color: #fff;

    display: grid;

    grid-template-columns:
      [full-start] 1fr
      [content] minmax(0, var(--content-width))
      1fr [full-end];
  }

  .flex-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: end;
    margin-bottom: 20px;
    margin-right: 20px;
  }

  .flex-container a {
    justify-self: right;
    width: fit-content;
    background-color: var(--color-surface-secondary);
    padding: 20px 30px 20px 30px;
    border-radius: 50px;
    text-decoration: none;

    &:hover {
      background-color: var(--color-surface-highlight);
    }
  }

  /* Selve kortet */
  .card {
    scroll-snap-align: start;
    border-radius: 25px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background-color: var(--color-surface-secondary);

    h2,
    h3 {
      margin-bottom: 20px;
    }

    a {
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }
  }
</style>
